{
  "name": "fillit",
  "version": "0.0.0",
  "private": true,
  "description": "Cross-platform mobile app for scanning, filling, and exporting documents",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "typecheck": "pnpm -r run typecheck",
    "clean": "rimraf node_modules apps/*/node_modules packages/*/node_modules",
    "test": "vitest run"
  },
  "pnpm": {
    "overrides": {
      "@infinitered/react-native-mlkit-core": "5.0.0",
      "flatted": ">=3.4.2",
      "node-forge": ">=1.4.0",
      "picomatch": ">=4.0.4",
      "@xmldom/xmldom": ">=0.8.12",
      "brace-expansion": ">=5.0.5",
      "yaml": ">=2.8.3"
    }
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.4.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0",
    "yaml": "^2.8.3"
  }
}
