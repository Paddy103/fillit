# FillIt Server Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# CORS (comma-separated origins, or leave empty for *)
CORS_ORIGINS=

# Google OAuth (get from console.cloud.google.com → Credentials → OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=

# Apple Sign-In (get from developer.apple.com → Certificates, Identifiers & Profiles)
APPLE_CLIENT_ID=

# Dev tokens — accepts "dev:<userId>" for local testing (default: true in dev, false in prod)
AUTH_DEV_TOKENS=true

# Anthropic / Claude API (get from console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=
# Optional: override model (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514
# Optional: override max tokens (default: 4096)
# CLAUDE_MAX_TOKENS=4096
