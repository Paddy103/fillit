{
  "expo": {
    "name": "FillIt",
    "slug": "fillit",
    "owner": "paddy103",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fillit",
    "userInterfaceStyle": "automatic",
    "platforms": ["ios", "android"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.paddy103.fillit",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "FillIt uses the camera to scan documents for form filling."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0066CC"
      },
      "package": "com.fillit.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "backgroundColor": "#1B1B3A",
          "dark": {
            "image": "./assets/images/icon.png",
            "imageWidth": 200,
            "backgroundColor": "#121212"
          }
        }
      ],
      "expo-font",
      "expo-sharing",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bb934463-b846-43b3-b229-f2757cc93dfb"
      }
    }
  }
}
